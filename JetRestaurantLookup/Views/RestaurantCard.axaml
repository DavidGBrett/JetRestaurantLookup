<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JetRestaurantLookup.ViewModels"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="JetRestaurantLookup.Views.RestaurantCard"
             x:DataType="vm:RestaurantCardViewModel">

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="8" Margin="4">
        <StackPanel Orientation="Vertical" Spacing="2" Margin="12,10">

        <Grid ColumnDefinitions="64,*,92" RowDefinitions="Auto,Auto">
            <Border Grid.Column="0" Grid.RowSpan="2"
                    Width="64" Height="64"
                    CornerRadius="4"
                    BorderBrush="Gray" BorderThickness="2">
                <Border CornerRadius="4" ClipToBounds="True">
                    <Image Stretch="UniformToFill"
                           asyncImageLoader:ImageLoader.Source="{Binding LogoUrl}" />
                </Border>
            </Border>

            <SelectableTextBlock Grid.Column="1" Grid.Row="0"
                       Text="{Binding Name}"
                       FontSize="18" FontWeight="Bold"
                       TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                       Margin="10,0,8,0"
                       VerticalAlignment="Top" />

            <ItemsControl Grid.Column="1" Grid.Row="1" Margin="10,2,8,0" ItemsSource="{Binding Cuisines}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Gray" CornerRadius="10" Padding="6,2" Margin="0,0,4,2">
                            <SelectableTextBlock Text="{Binding}" FontSize="12" Foreground="White" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Grid.Column="2" Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                <SelectableTextBlock Text="{Binding RatingScore}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource SystemControlHighlightAccentBrush}"
                           HorizontalAlignment="Center" />
                <SelectableTextBlock Text="{Binding RatingCountText}"
                           FontSize="13" FontWeight="Normal"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
            <SelectableTextBlock Text="{Binding Address}" FontSize="12" TextWrapping="Wrap"
                                 Width="120" VerticalAlignment="Center" />
            <Button Content="🌍 Open In Google Maps" Command="{Binding OpenGoogleMapsCommand}"
                    FontSize="11" Padding="6,3" VerticalAlignment="Center" />
            <Button Content="🍕 View on Just Eat" Command="{Binding OpenJustEatCommand}"
                    FontSize="11" Padding="6,3" VerticalAlignment="Center" />
        </StackPanel>
    </StackPanel>
    </Border>

</UserControl>
