<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:JetRestaurantLookup.ViewModels"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             x:Class="JetRestaurantLookup.Views.RestaurantCard"
             x:DataType="vm:RestaurantCardViewModel">

    <StackPanel Orientation="Vertical" Spacing="2" Margin="4">

        <Grid ColumnDefinitions="64,*" RowDefinitions="Auto,Auto">
            <Border Grid.Column="0" Grid.RowSpan="2"
                    Width="64" Height="64"
                    CornerRadius="4"
                    BorderBrush="Gray" BorderThickness="2">
                <Border CornerRadius="4" ClipToBounds="True">
                    <Image Stretch="UniformToFill"
                           asyncImageLoader:ImageLoader.Source="{Binding LogoUrl}" />
                </Border>
            </Border>

            <Grid Grid.Column="1" Grid.Row="0" ColumnDefinitions="*,Auto" Margin="10,0,0,0">
                <TextBlock Grid.Column="0"
                           Text="{Binding Name}"
                           FontSize="18" FontWeight="Bold"
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                           VerticalAlignment="Top" />
                <TextBlock Grid.Column="1"
                           Text="{Binding RatingSummary}"
                           FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Top"
                           Margin="8,0,0,0" />
            </Grid>

            <ItemsControl Grid.Column="1" Grid.Row="1" Margin="10,2,0,0" ItemsSource="{Binding Cuisines}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="14" FontWeight="Bold" Margin="0,0,6,0" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <TextBlock Text="{Binding AddressLine1}" FontSize="12" TextWrapping="Wrap" Margin="0,6,0,0" />
        <TextBlock Text="{Binding AddressLine2}" FontSize="12" TextWrapping="Wrap" />

    </StackPanel>

</UserControl>
